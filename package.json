{
  "name": "@avoidray/click-to-source",
  "version": "0.0.1",
  "publishConfig": {
    "access": "public"
  },
  "description": "Alt+click any element to open its source in VS Code",
  "author": {
    "name": "avoidray",
    "url": "https://github.com/avoidray"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/avoidray/click-to-source.git"
  },
  "bugs": {
    "url": "https://github.com/avoidray/click-to-source/issues"
  },
  "homepage": "https://github.com/avoidray/click-to-source#readme",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "exports": {
    ".": {
      "types": "./runtime.d.ts",
      "import": "./runtime.js"
    },
    "./vite": {
      "types": "./vite.d.ts",
      "import": "./vite.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "runtime.js",
    "runtime.d.ts",
    "vite.js",
    "vite.d.ts",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "test": "node --test",
    "prepublishOnly": "node --test"
  },
  "keywords": [
    "vite-plugin",
    "react",
    "devtools",
    "vscode",
    "source"
  ],
  "license": "MIT",
  "peerDependencies": {
    "vite": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    }
  }
}
